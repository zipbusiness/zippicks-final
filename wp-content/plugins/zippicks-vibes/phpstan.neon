includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    level: 6
    paths:
        - src/
        - includes/
        - zippicks-vibes-v2.php
    excludePaths:
        - tests/
        - vendor/
        - assets/
        - docs/
        - templates/
        - node_modules/
        - .phpunit.cache/
        analyse:
            - src/**/*.php
            - includes/**/*.php
    scanFiles:
        - zippicks-vibes-v2.php
    scanDirectories:
        - src/
    bootstrapFiles:
        - tests/phpstan-bootstrap.php
    dynamicConstantNames:
        - ZIPPICKS_VIBES_VERSION
        - ZIPPICKS_VIBES_PLUGIN_FILE
        - ZIPPICKS_VIBES_PLUGIN_DIR
        - ZIPPICKS_VIBES_PLUGIN_URL
        - ZIPPICKS_VIBES_TEST_MODE
    universalObjectCratesClasses:
        - stdClass
        - WP_Post
        - WP_Term
        - WP_User
        - WP_Error
    earlyTerminatingMethodCalls:
        WP_Error:
            - add
    earlyTerminatingFunctionCalls:
        - wp_die
        - wp_send_json
        - wp_send_json_error
        - wp_send_json_success
        - exit
        - die
    ignoreErrors:
        # WordPress global functions
        - '#Function apply_filters invoked with#'
        - '#Function do_action invoked with#'
        - '#Access to an undefined property WP_Error#'
        - '#Call to an undefined method WP_Error#'
        
        # WordPress hooks
        - '#Parameter \$[a-zA-Z0-9_]+ of function add_filter expects#'
        - '#Parameter \$[a-zA-Z0-9_]+ of function add_action expects#'
        
        # WordPress globals
        - '#Variable \$wpdb might not be defined#'
        - '#Variable \$wp_version might not be defined#'
        
        # Dynamic properties common in WordPress
        - '#Access to an undefined property object::\$[a-zA-Z0-9_]+#'
        
        # WordPress functions that might not exist in test environment
        - '#Function wp_[a-zA-Z0-9_]+ not found#'
        - '#Function get_[a-zA-Z0-9_]+ not found#'
        
        # Known ZipPicks patterns
        - '#Call to function zippicks\(\) on a separate line#'
        - '#Method ZipPicks\\Foundation\\Container::[a-zA-Z0-9_]+ invoked with#'
        
        # Baseline for existing issues
        -
            message: '#Method .+ has parameter .+ with no type specified#'
            path: src/Services/RenderingService.php
        -
            message: '#Property .+ has no type specified#'
            path: src/Models/*.php
            
    reportUnmatchedIgnoredErrors: false
    treatPhpDocTypesAsCertain: false
    checkGenericClassInNonGenericObjectType: false
    checkMissingIterableValueType: false
    checkAlwaysTrueCheckTypeFunctionCall: false
    checkAlwaysTrueInstanceof: false
    checkAlwaysTrueStrictComparison: false
    polluteScopeWithLoopInitialAssignments: true
    polluteScopeWithAlwaysIterableForeach: true
    
services:
    -
        class: PHPStan\WordPress\GetPostDynamicFunctionReturnTypeExtension
        tags:
            - phpstan.broker.dynamicFunctionReturnTypeExtension