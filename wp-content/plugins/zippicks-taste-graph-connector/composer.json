{
    "name": "zippicks/zippicks-taste-graph-connector",
    "description": "WordPress plugin to connect to ZipBusiness Taste Graph for personalized restaurant recommendations",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "ZipPicks",
            "email": "dev@zippicks.com",
            "homepage": "https://zippicks.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=7.4",
        "firebase/php-jwt": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^3.6",
        "wp-coding-standards/wpcs": "^2.3",
        "dealerdirect/phpcodesniffer-composer-installer": "^0.7 || ^1.0"
    },
    "autoload": {
        "psr-4": {
            "TasteGraphConnector\\": "includes/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpcs": "phpcs --standard=WordPress --extensions=php --ignore=vendor,node_modules .",
        "phpcbf": "phpcbf --standard=WordPress --extensions=php --ignore=vendor,node_modules .",
        "install-codestandards": [
            "Dealerdirect\\Composer\\Plugin\\Installers\\PHPCodeSniffer\\Plugin::run"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "wordpress-plugin-name": "ZipPicks Taste Graph Connector",
        "wordpress-plugin-uri": "https://zippicks.com/",
        "wordpress-plugin-textdomain": "zippicks-taste-graph-connector"
    }
}